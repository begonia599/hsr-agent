DATABASE_URL=postgresql://hsr:hsr@localhost:55432/hsr_agent

# Default LLM provider: OpenAI-compatible chat completions.
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=replace-me
LLM_MODEL=deepseek-chat
LLM_API_FORMAT=openai

HSR_DATA_VERSION=4.3.54
HSR_DATA_DIR=nanoka_hsr/4.3.54

# HTTP server (go run ./cmd/hsr-agent --serve)
HTTP_ADDR=127.0.0.1:8080
# 前端构建产物目录;前端 npm run build 输出到 hsr-agent-go/web/dist
WEB_ROOT=web/dist
# 语义搜索 embedding 提供方:disabled / openai_compatible / ollama
# 当前默认 disabled(本地 hash embedding 不作为语义搜索对外暴露)
EMBEDDING_PROVIDER=disabled
