DATABASE_URL=postgresql://hsr:hsr@localhost:55432/hsr_agent

# Default LLM provider: OpenAI-compatible chat completions.
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=replace-me
LLM_MODEL=deepseek-chat
LLM_API_FORMAT=openai

HSR_DATA_VERSION=4.3.54
HSR_DATA_DIR=nanoka_hsr/4.3.54

# HTTP server (go run ./cmd/hsr-agent --serve)
HTTP_ADDR=127.0.0.1:8080
# 前端构建产物目录;前端 npm run build 输出到 hsr-agent-go/web/dist
WEB_ROOT=web/dist
# 语义搜索 embedding 提供方:disabled / openai_compatible / ollama
# 当前默认 disabled(本地 hash embedding 不作为语义搜索对外暴露)
EMBEDDING_PROVIDER=disabled
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1024
EMBEDDING_ENCODING_FORMAT=float
EMBEDDING_QUERY_CACHE_TTL_SECONDS=600
EMBEDDING_QUERY_CACHE_MAX_ENTRIES=256
# 逗号分隔,例如: X-Failover-Enabled:true
EMBEDDING_EXTRA_HEADERS=

# 多 embedding 模型 catalog;前端通过 GET /api/models 获取 id/状态。
# 只有在 DB entity_embeddings 中三类实体全量覆盖的模型才会 ready/selectable。
EMBEDDING_DEFAULT_ID=bge-m3
EMBEDDING_MODEL_IDS=bge-m3,qwen3-embedding-8b
EMBEDDING_MODEL_BGE_M3_LABEL=bge-m3
EMBEDDING_MODEL_BGE_M3_PROVIDER=openai_compatible
EMBEDDING_MODEL_BGE_M3_BASE_URL=https://api.example.com/v1
EMBEDDING_MODEL_BGE_M3_API_KEY=replace-me
EMBEDDING_MODEL_BGE_M3_MODEL=bge-m3
EMBEDDING_MODEL_BGE_M3_DIMENSIONS=1024
EMBEDDING_MODEL_BGE_M3_NATIVE_DIMENSIONS=1024
EMBEDDING_MODEL_BGE_M3_PROJECTION_STRATEGY=none
EMBEDDING_MODEL_BGE_M3_ENCODING_FORMAT=float
EMBEDDING_MODEL_BGE_M3_EXTRA_HEADERS=
EMBEDDING_MODEL_QWEN3_EMBEDDING_8B_LABEL=Qwen3-Embedding-8B
EMBEDDING_MODEL_QWEN3_EMBEDDING_8B_PROVIDER=openai_compatible
EMBEDDING_MODEL_QWEN3_EMBEDDING_8B_BASE_URL=https://api.example.com/v1
EMBEDDING_MODEL_QWEN3_EMBEDDING_8B_API_KEY=replace-me
EMBEDDING_MODEL_QWEN3_EMBEDDING_8B_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_MODEL_QWEN3_EMBEDDING_8B_DIMENSIONS=1024
EMBEDDING_MODEL_QWEN3_EMBEDDING_8B_NATIVE_DIMENSIONS=4096
EMBEDDING_MODEL_QWEN3_EMBEDDING_8B_PROJECTION_STRATEGY=truncate_1024
EMBEDDING_MODEL_QWEN3_EMBEDDING_8B_ENCODING_FORMAT=float

# 多 reranker 模型 catalog;reranker 只用于召回后的精排,可由前端选择。
RERANK_DEFAULT_ID=bge-reranker-v2-m3
RERANK_TOP_N=25
RERANK_MODEL_IDS=bge-reranker-v2-m3,bce-reranker-base-v1
RERANK_MODEL_BGE_RERANKER_V2_M3_LABEL=bge-reranker-v2-m3
RERANK_MODEL_BGE_RERANKER_V2_M3_PROVIDER=openai_compatible
RERANK_MODEL_BGE_RERANKER_V2_M3_BASE_URL=https://api.example.com/v1
RERANK_MODEL_BGE_RERANKER_V2_M3_API_KEY=replace-me
RERANK_MODEL_BGE_RERANKER_V2_M3_MODEL=bge-reranker-v2-m3
RERANK_MODEL_BGE_RERANKER_V2_M3_EXTRA_HEADERS=
RERANK_MODEL_BGE_RERANKER_V2_M3_CONTEXT_LENGTH=8192
RERANK_MODEL_BCE_RERANKER_BASE_V1_LABEL=bce-reranker-base_v1
RERANK_MODEL_BCE_RERANKER_BASE_V1_PROVIDER=openai_compatible
RERANK_MODEL_BCE_RERANKER_BASE_V1_BASE_URL=https://api.example.com/v1
RERANK_MODEL_BCE_RERANKER_BASE_V1_API_KEY=replace-me
RERANK_MODEL_BCE_RERANKER_BASE_V1_MODEL=bce-reranker-base_v1
RERANK_MODEL_BCE_RERANKER_BASE_V1_CONTEXT_LENGTH=512
